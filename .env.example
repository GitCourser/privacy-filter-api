# privacy-filter-api 配置示例
# 优先级：命令行参数 > .env/环境变量 > 默认值

# 服务监听 IP；对应命令行参数：--host
HOST=127.0.0.1

# 服务监听端口；对应命令行参数：--port
PORT=4175

# API Key；为空表示不启用鉴权；非空时 /detect 和 /mask 需要请求头 x-api-key；对应命令行参数：--api-key
API_KEY=

# 模型仓库 ID；默认 openai/privacy-filter；对应命令行参数：--model-id
MODEL_ID=openai/privacy-filter

# ONNX 型号；可选 fp32、fp16、q4、q4f16、quantized；对应命令行参数：--onnx-variant
ONNX_VARIANT=fp32

# 本地模型根目录；实际文件位于 MODEL_DIR/MODEL_ID/；启动时缺少本地模型且 MODEL_CHECK=true 时会按 ONNX_VARIANT 自动下载；对应命令行参数：--model-dir
MODEL_DIR=./models

# 是否检测本地模型并在缺失时自动下载；默认为 true；对应命令行参数：--model-check
MODEL_CHECK=true

# 单次推理最大 token 数；对应命令行参数：--max-tokens
MAX_TOKENS=128000

# ONNX Runtime OpenMP 线程数；默认 1；内存充裕时可设为 CPU 核心数以加速推理；对应命令行参数：--omp-num-threads
OMP_NUM_THREADS=1
